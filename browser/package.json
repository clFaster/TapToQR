{
  "name": "tap-to-qr",
  "version": "0.0.0",
  "description": "Turn any page into a QR code in seconds. TapToQR is a lightweight browser extension for sharing pages and custom content.",
  "license": "GPL-3.0",
  "author": "Moritz Reis",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.1+sha512.3590e550d5384caa39bd5c7c739f72270234b2f6059e13018f975c313b1eb9fefcc09714048765d4d9efe961382c312e624572c0420762bdc5d5940cdf9be73a",
  "scripts": {
    "dev": "vite build --watch",
    "start:firefox": "concurrently -k -n BUILD,FIREFOX -c cyan,magenta \"pnpm dev\" \"pnpm start:firefox:browser\"",
    "start:firefox:browser": "web-ext run --start-url https://mozilla.org --browser-console --source-dir build",
    "start:edge": "concurrently -k -n BUILD,EDGE -c cyan,green \"pnpm dev\" \"pnpm start:edge:browser\"",
    "start:edge:browser": "web-ext run --target chromium --chromium-binary \"C:\\Program Files (x86)\\Microsoft\\Edge\\Application\\msedge.exe\" --start-url https://www.microsoft.com --source-dir build",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "catalog:",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "catalog:",
    "@fortawesome/react-fontawesome": "catalog:",
    "jimp": "^1.6.1",
    "qrcode": "^1.5.4",
    "react": "catalog:",
    "react-dom": "catalog:",
    "styled-components": "^6.4.0",
    "vite-plugin-static-copy": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "catalog:",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "catalog:",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "web-ext": "^10.1.0",
    "webextension-polyfill": "^0.12.0"
  }
}